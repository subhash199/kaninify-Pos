    public class CloudSetupModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [StringLength(50, MinimumLength = 6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "API URL is required")]
        [Url(ErrorMessage = "Please enter a valid URL")]
        public string ApiUrl { get; set; } = string.Empty;

        [Required(ErrorMessage = "API Key is required")]
        public string ApiKey { get; set; } = string.Empty;
    }


    private async Task SetupCloudSync()
    {
        isLoading = true;
        errorMessage = string.Empty;
        StateHasChanged();
        Retailer retailer;

        try
        {

            var authResult = await SupabaseSyncService.AuthenticateAsync(cloudSetupModel.Email, cloudSetupModel.Password, cloudSetupModel.ApiUrl, cloudSetupModel.ApiKey);

            if (authResult.IsSuccess)
            {
                Retailer tempRetailer = new Retailer
                {
                    RetailerId = Guid.Parse(authResult.UserId),
                    Email = cloudSetupModel.Email,
                    ApiUrl = cloudSetupModel.ApiUrl,
                    Password = cloudSetupModel.Password,
                    ApiKey = cloudSetupModel.ApiKey,
                    AccessToken = authResult.AccessToken,
                    RefreshToken = authResult.RefreshToken,
                    TokenExpiryAt = authResult.ExpiresAt,
                    IsActive = true,
                    Date_Created = DateTime.UtcNow,
                    Last_Modified = DateTime.UtcNow,
                    Last_Sign_In_At = DateTime.UtcNow,
                    SyncStatus = SyncStatus.Pending
                };
                var result = await SupabaseSyncService.GetAsync<Retailer>(tempRetailer, "Retailers", "*", $"Email=eq.{cloudSetupModel.Email}", null);

                if (result.Error != null)
                {
                    // Show error message when account doesn't exist
                    errorMessage = $"Your account may not exist or {result.Error}. Please contact tech support.";
                    isLoading = false;
                    StateHasChanged();
                    return;
                }
                else
                {
                    if (result.Data == null || result.Data.Count == 0)
                    {
                        errorMessage = "No retailer found with the provided email. Please contact tech support.";
                        isLoading = false;
                        StateHasChanged();
                        return;
                    }
                    retailer = result.Data[0];
                    retailer.ApiKey = cloudSetupModel.ApiKey;
                    // Update existing retailer with new tokens
                    retailer.ApiUrl = cloudSetupModel.ApiUrl;
                    retailer.Password = cloudSetupModel.Password;
                    retailer.AccessToken = authResult.AccessToken;
                    retailer.RefreshToken = authResult.RefreshToken;
                    retailer.TokenExpiryAt = authResult.ExpiresAt;
                    retailer.Last_Modified = DateTime.UtcNow;
                    retailer.Last_Sign_In_At = DateTime.UtcNow;
                    retailer.Date_Created = retailer.Date_Created.ToUniversalTime();
                    retailer.LastLicenseCheck = retailer.LastLicenseCheck == null ? null : retailer.LastLicenseCheck.Value.ToUniversalTime();
                    retailer.LicenseIssueDate = retailer.LicenseIssueDate.ToUniversalTime();
                    retailer.LicenseExpiryDate = retailer.LicenseExpiryDate.ToUniversalTime();
                    retailer.LastSyncedAt = retailer.LastSyncedAt == null ? null : retailer.LastSyncedAt.Value.ToUniversalTime();
                    retailer.IsActive = true;
                    retailer.SyncStatus = SyncStatus.Pending;

                    await RetailerServices.DeleteAllAsync();
                    await RetailerServices.AddAsync(retailer);
                }

                cloudSyncSuccess = true;
                if (createdSite == null || createdTill == null || createdUser == null)
                {
                    var importResult = await ImportSetupDataFromCloudAsync(retailer);
                    if (!string.IsNullOrWhiteSpace(importResult.Error))
                    {
                        errorMessage = importResult.Error;
                        return;
                    }

                    var missingStep = GetFirstMissingStep(importResult.HasSites, importResult.HasTills, importResult.HasUsers, importResult.HasPrinters);
                    if (missingStep.HasValue)
                    {
                        currentStep = missingStep.Value;
                        StateHasChanged();
                        return;
                    }
                }
                NextStep();
            }
            else
            {
                errorMessage = $"Authentication failed: {authResult.ErrorMessage}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error setting up cloud sync: {ex.Message}";
            await GlobalErrorLogService.LogErrorAsync(ex, nameof(SetupCloudSync), "Failed to setup cloud sync during system setup");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SkipCloudSetup()
    {
        // Skip cloud setup and move to completion
        NextStep();
    }

    private void StartCloudSetup()
    {
        errorMessage = string.Empty;
        currentStep = SetupStep.CloudSetup;
        StateHasChanged();
    }

    private SetupStep? GetFirstMissingStep(bool hasSites, bool hasTills, bool hasUsers, bool hasPrinters)
    {
        if (!hasSites) return SetupStep.Site;
        if (!hasTills) return SetupStep.Till;
        if (!hasUsers) return SetupStep.User;
        if (!hasPrinters) return SetupStep.Printer;
        return null;
    }

    private async Task<(bool HasSites, bool HasTills, bool HasUsers, bool HasPrinters, string? Error)> ImportSetupDataFromCloudAsync(Retailer retailer)
    {
        try
        {
            var siteIdMap = new Dictionary<int, int>();
            var tillIdMap = new Dictionary<int, int>();
            var userIdMap = new Dictionary<int, int>();
            var siteAuditAssignments = new List<(Site Site, int? CreatedById, int? LastModifiedById)>();
            var tillAuditAssignments = new List<(Till Till, int? CreatedById, int? LastModifiedById)>();
            var userAuditAssignments = new Dictionary<int, (int? CreatedById, int? LastModifiedById)>();

            var sitesResult = await SupabaseSyncService.GetAsync<SupaSites>(retailer, "Sites", "*", $"RetailerId=eq.{retailer.RetailerId}");
            if (!sitesResult.IsSuccess)
            {
                return (false, false, false, false, sitesResult.Error ?? "Failed to fetch sites from cloud.");
            }

            var siteEntities = new List<Site>();
            foreach (var supaSite in sitesResult.Data ?? new List<SupaSites>())
            {
                var site = new Site
                {
                    Supa_Id = supaSite.Supa_Id,
                    Site_BusinessName = supaSite.Site_BusinessName,
                    Site_AddressLine1 = supaSite.Site_AddressLine1,
                    Site_AddressLine2 = supaSite.Site_AddressLine2,
                    Site_City = supaSite.Site_City,
                    Site_County = supaSite.Site_County,
                    Site_Country = supaSite.Site_Country,
                    Site_Postcode = supaSite.Site_Postcode,
                    Site_ContactNumber = supaSite.Site_ContactNumber,
                    Site_Email = supaSite.Site_Email,
                    Site_VatNumber = supaSite.Site_VatNumber,
                    Is_Primary = supaSite.Is_Primary,
                    Is_Active = supaSite.Is_Active,
                    Is_Deleted = supaSite.Is_Deleted,
                    Date_Created = supaSite.Date_Created.ToUniversalTime(),
                    Last_Modified = supaSite.Last_Modified.ToUniversalTime(),
                    Created_By_Id = null,
                    Last_Modified_By_Id = null,
                    SyncStatus = SyncStatus.Synced
                };

                await UpsertSiteAsync(site);
                if (site.Id != 0)
                {
                    siteIdMap[supaSite.Site_Id] = site.Id;
                }
                siteAuditAssignments.Add((site, supaSite.Created_By_Id, supaSite.Last_Modified_By_Id));
                siteEntities.Add(site);
            }

            if (createdSite == null && siteEntities.Any())
            {
                createdSite = siteEntities
                    .Where(s => s.Is_Active && !s.Is_Deleted)
                    .OrderByDescending(s => s.Is_Primary)
                    .ThenBy(s => s.Id)
                    .FirstOrDefault() ?? siteEntities.First();
            }

            var tillsResult = await SupabaseSyncService.GetAsync<SupaTills>(retailer, "Tills", "*", $"RetailerId=eq.{retailer.RetailerId}");
            if (!tillsResult.IsSuccess)
            {
                return (siteEntities.Any(), false, false, false, tillsResult.Error ?? "Failed to fetch tills from cloud.");
            }

            var tillEntities = new List<Till>();
            foreach (var supaTill in tillsResult.Data ?? new List<SupaTills>())
            {
                var mappedSiteId = MapId(siteIdMap, supaTill.Site_Id) ?? createdSite?.Id;
                var till = new Till
                {
                    Supa_Id = supaTill.Supa_Id,
                    Till_Name = supaTill.Till_Name,
                    Till_IP_Address = supaTill.Till_IP_Address,
                    Till_Port_Number = supaTill.Till_Port_Number,
                    Till_Password = supaTill.Till_Password,
                    Is_Primary = supaTill.Is_Primary,
                    Is_Active = supaTill.Is_Active,
                    Is_Deleted = supaTill.Is_Deleted,
                    Date_Created = supaTill.Date_Created.ToUniversalTime(),
                    Last_Modified = supaTill.Last_Modified.ToUniversalTime(),
                    Created_By_Id = null,
                    Last_Modified_By_Id = null,
                    Site_Id = mappedSiteId,
                    SyncStatus = SyncStatus.Synced
                };

                await UpsertTillAsync(till);
                if (till.Id != 0)
                {
                    tillIdMap[supaTill.Till_Id] = till.Id;
                }
                tillAuditAssignments.Add((till, supaTill.Created_By_Id, supaTill.Last_Modified_By_Id));
                tillEntities.Add(till);
            }

            if (createdTill == null && tillEntities.Any())
            {
                createdTill = tillEntities
                    .Where(t => t.Is_Active && !t.Is_Deleted && (createdSite == null || t.Site_Id == createdSite.Id))
                    .OrderByDescending(t => t.Is_Primary)
                    .ThenBy(t => t.Id)
                    .FirstOrDefault() ?? tillEntities.First();
            }

            var usersResult = await SupabaseSyncService.GetAsync<SupaPosUsers>(retailer, "PosUsers", "*", $"RetailerId=eq.{retailer.RetailerId}");
            if (!usersResult.IsSuccess)
            {
                return (siteEntities.Any(), tillEntities.Any(), false, false, usersResult.Error ?? "Failed to fetch users from cloud.");
            }

            var userEntities = new List<PosUser>();
            foreach (var supaUser in usersResult.Data ?? new List<SupaPosUsers>())
            {
                var mappedPrimarySiteId = MapId(siteIdMap, supaUser.Primary_Site_Id);
                var mappedSiteId = MapId(siteIdMap, supaUser.Site_Id);
                var mappedTillId = MapId(tillIdMap, supaUser.Till_Id);
                var user = new PosUser
                {
                    Supa_Id = supaUser.Supa_Id,
                    First_Name = supaUser.First_Name,
                    Last_Name = supaUser.Last_Name,
                    Passcode = supaUser.Passcode,
                    User_Type = supaUser.User_Type,
                    Primary_Site_Id = mappedPrimarySiteId,
                    Allowed_Void_Line = supaUser.Allowed_Void_Line,
                    Allowed_Void_Sale = supaUser.Allowed_Void_Sale,
                    Allowed_No_Sale = supaUser.Allowed_No_Sale,
                    Allowed_Returns = supaUser.Allowed_Returns,
                    Allowed_Payout = supaUser.Allowed_Payout,
                    Allowed_Refund = supaUser.Allowed_Refund,
                    Allowed_Change_Price = supaUser.Allowed_Change_Price,
                    Allowed_Discount = supaUser.Allowed_Discount,
                    Allowed_Override_Price = supaUser.Allowed_Override_Price,
                    Allowed_Manage_Users = supaUser.Allowed_Manage_Users,
                    Allowed_Manage_Sites = supaUser.Allowed_Manage_Sites,
                    Allowed_Manage_Tills = supaUser.Allowed_Manage_Tills,
                    Allowed_Manage_Products = supaUser.Allowed_Manage_Products,
                    Allowed_Manage_Suppliers = supaUser.Allowed_Manage_Suppliers,
                    Allowed_Manage_StockTransfer = supaUser.Allowed_Manage_StockTransfer,
                    Allowed_Manage_Vat = supaUser.Allowed_Manage_Vat,
                    Allowed_Manage_Departments = supaUser.Allowed_Manage_Departments,
                    Allowed_Manage_Orders = supaUser.Allowed_Manage_Orders,
                    Allowed_Manage_Reports = supaUser.Allowed_Manage_Reports,
                    Allowed_Manage_Settings = supaUser.Allowed_Manage_Settings,
                    Allowed_Manage_Tax_Rates = supaUser.Allowed_Manage_Tax_Rates,
                    Allowed_Manage_Promotions = supaUser.Allowed_Manage_Promotions,
                    Allowed_Manage_VoidedProducts = supaUser.Allowed_Manage_VoidedProducts,
                    Allowed_Day_End = supaUser.Allowed_Day_End,
                    Is_Activated = supaUser.Is_Activated,
                    Is_Deleted = supaUser.Is_Deleted,
                    Date_Created = supaUser.Date_Created.ToUniversalTime(),
                    Last_Modified = supaUser.Last_Modified.ToUniversalTime(),
                    Created_By_Id = null,
                    Last_Modified_By_Id = null,
                    Site_Id = mappedSiteId,
                    Till_Id = mappedTillId,
                    SyncStatus = SyncStatus.Synced
                };

                await UpsertUserAsync(user);
                if (user.Id != 0)
                {
                    userIdMap[supaUser.User_ID] = user.Id;
                }
                userAuditAssignments[supaUser.User_ID] = (supaUser.Created_By_Id, supaUser.Last_Modified_By_Id);
                userEntities.Add(user);
            }

            if (createdUser == null && userEntities.Any())
            {
                createdUser = userEntities
                    .Where(u => u.Is_Activated && !u.Is_Deleted)
                    .OrderByDescending(u => u.User_Type == PosUserType.Director)
                    .ThenBy(u => u.Id)
                    .FirstOrDefault() ?? userEntities.First();
            }

            foreach (var (site, createdById, lastModifiedById) in siteAuditAssignments)
            {
                site.Created_By_Id = MapUserId(userIdMap, createdById, createdUser?.Id);
                site.Last_Modified_By_Id = MapUserId(userIdMap, lastModifiedById, createdUser?.Id);
                await UpsertSiteAsync(site);
            }

            foreach (var (till, createdById, lastModifiedById) in tillAuditAssignments)
            {
                till.Created_By_Id = MapUserId(userIdMap, createdById, createdUser?.Id);
                till.Last_Modified_By_Id = MapUserId(userIdMap, lastModifiedById, createdUser?.Id);
                await UpsertTillAsync(till);
            }

            foreach (var userAuditEntry in userAuditAssignments)
            {
                if (!userIdMap.TryGetValue(userAuditEntry.Key, out var localUserId))
                {
                    continue;
                }

                var user = userEntities.FirstOrDefault(u => u.Id == localUserId) ?? await PosUserServices.GetByIdAsync(localUserId);
                if (user == null)
                {
                    continue;
                }

                user.Created_By_Id = MapUserId(userIdMap, userAuditEntry.Value.CreatedById, createdUser?.Id ?? localUserId);
                user.Last_Modified_By_Id = MapUserId(userIdMap, userAuditEntry.Value.LastModifiedById, createdUser?.Id ?? localUserId);
                await UpsertUserAsync(user);
            }

            var printersResult = await SupabaseSyncService.GetAsync<SupaReceiptPrinters>(retailer, "ReceiptPrinters", "*", $"RetailerId=eq.{retailer.RetailerId}");
            if (!printersResult.IsSuccess)
            {
                return (siteEntities.Any(), tillEntities.Any(), userEntities.Any(), false, printersResult.Error ?? "Failed to fetch printers from cloud.");
            }

            var printerEntities = new List<ReceiptPrinter>();
            foreach (var supaPrinter in printersResult.Data ?? new List<SupaReceiptPrinters>())
            {
                var mappedSiteId = MapId(siteIdMap, supaPrinter.Site_Id);
                var mappedTillId = MapId(tillIdMap, supaPrinter.Till_Id);
                var printer = new ReceiptPrinter
                {
                    Supa_Id = supaPrinter.Supa_Id,
                    Printer_Name = supaPrinter.Printer_Name,
                    Printer_IP_Address = supaPrinter.Printer_IP_Address,
                    Printer_Port_Number = supaPrinter.Printer_Port_Number,
                    Printer_Password = supaPrinter.Printer_Password,
                    Paper_Width = supaPrinter.Paper_Width,
                    Is_Active = supaPrinter.Is_Active,
                    Is_Deleted = supaPrinter.Is_Deleted,
                    Date_Created = supaPrinter.Date_Created.ToUniversalTime(),
                    Last_Modified = supaPrinter.Last_Modified.ToUniversalTime(),
                    Created_By_Id = MapUserId(userIdMap, supaPrinter.Created_By_Id, createdUser?.Id),
                    Last_Modified_By_Id = MapUserId(userIdMap, supaPrinter.Last_Modified_By_Id, createdUser?.Id),
                    Site_Id = mappedSiteId,
                    Till_Id = mappedTillId,
                    Is_Primary = supaPrinter.Is_Primary,
                    Print_Receipt = supaPrinter.Print_Receipt,
                    Print_Label = supaPrinter.Print_Label,
                    SyncStatus = SyncStatus.Synced
                };

                await UpsertPrinterAsync(printer);
                printerEntities.Add(printer);
            }

            return (siteEntities.Any(), tillEntities.Any(), userEntities.Any(), printerEntities.Any(), null);
        }
        catch (Exception ex)
        {
            return (false, false, false, false, $"Error importing cloud data: {ex.Message}");
        }
    }

    private async Task UpsertSiteAsync(Site site)
    {
        Site? existing = null;
        if (site.Supa_Id.HasValue)
        {
            existing = (await SiteServices.GetByConditionAsync(s => s.Supa_Id == site.Supa_Id, false)).FirstOrDefault();
        }
        if (existing == null && site.Id != 0)
        {
            existing = await SiteServices.GetByIdAsync(site.Id);
        }
        if (existing == null)
        {
            await SiteServices.AddAsync(site);
        }
        else
        {
            site.Id = existing.Id;
            await SiteServices.UpdateAsync(site);
        }
    }

    private async Task UpsertTillAsync(Till till)
    {
        Till? existing = null;
        if (till.Supa_Id.HasValue)
        {
            existing = (await TillServices.GetByConditionAsync(t => t.Supa_Id == till.Supa_Id, false)).FirstOrDefault();
        }
        if (existing == null && till.Id != 0)
        {
            existing = await TillServices.GetByIdAsync(till.Id);
        }
        if (existing == null)
        {
            await TillServices.AddAsync(till);
        }
        else
        {
            till.Id = existing.Id;
            await TillServices.UpdateAsync(till);
        }
    }

