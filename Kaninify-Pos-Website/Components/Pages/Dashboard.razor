@page "/dashboard"
@using DataHandlerLibrary.Services
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject UserSessionService UserSession


<div class="container-fluid px-4">
    <div class="row mb-5">
        <div class="col-12">
            <h3 class="mb-4 text-muted fw-semibold">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>
                Dashboard
            </h3>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <h4 class="mb-4 text-muted fw-semibold">
                <i class="bi bi-bag-check me-2"></i>
                Sales & Customers
            </h4>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToEnquiry">
                <div class="card-icon bg-primary">
                    <img src="images/icons/svg/search_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" class="img-fluid mb-2" />
                </div>
                <div class="card-content">
                    <h5 class="card-title">Enquiry</h5>
                    <p class="card-description">Search and manage product details</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToTransactionHistory">
                <div class="card-icon bg-warning">
                    <img src="images/icons/svg/history_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" class="img-fluid mb-2" />
                </div>
                <div class="card-content">
                    <h5 class="card-title">Transaction History</h5>
                    <p class="card-description">View reports and analytics</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <h4 class="mb-4 text-muted fw-semibold">
                <i class="bi bi-box-seam me-2"></i>
                Inventory Operations
            </h4>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToInventoryDeliveriesManagement">
                <div class="card-icon bg-info">
                    <img src="images/icons/svg/add_shopping_cart_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" class="img-fluid mb-2" />
                </div>
                <div class="card-content">
                    <h5 class="card-title">Delivery</h5>
                    <p class="card-description">Receive and record deliveries</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToStockRefill">
                <div class="card-icon bg-success">
                    <img src="images/icons/svg/inventory_24dp_1F1F1F_FILL0_wght400_GRAD0_opsz24.svg" class="img-fluid mb-2" />
                </div>
                <div class="card-content">
                    <h5 class="card-title">Stock Refill</h5>
                    <p class="card-description">Refill stock and track quantities</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToInventoryTransfers">
                <div class="card-icon bg-gradient">
                    <i class="bi bi-arrow-left-right text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Transfers</h5>
                    <p class="card-description">Move stock between locations</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <h4 class="mb-4 text-muted fw-semibold">
                <i class="bi bi-archive me-2"></i>
                Inventory Catalog
            </h4>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToInventoryOrders">
                <div class="card-icon bg-purple">
                    <i class="bi bi-clipboard-check text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Orders</h5>
                    <p class="card-description">Generate and review stock orders</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToInventoryAlerts">
                <div class="card-icon bg-orange">
                    <i class="bi bi-exclamation-triangle text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Alerts</h5>
                    <p class="card-description">Monitor low stock and expiry alerts</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToInventoryProducts">
                <div class="card-icon bg-info">
                    <i class="bi bi-boxes text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Products</h5>
                    <p class="card-description">Manage product listings</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToInventorySuppliers">
                <div class="card-icon bg-success">
                    <i class="bi bi-truck text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Suppliers</h5>
                    <p class="card-description">Maintain supplier contacts</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToInventorySupplierItems">
                <div class="card-icon bg-secondary">
                    <i class="bi bi-tags text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Supplier Items</h5>
                    <p class="card-description">Review supplier item mappings</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <h4 class="mb-4 text-muted fw-semibold">
                <i class="bi bi-graph-up me-2"></i>
                Reports
            </h4>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToShiftReport">
                <div class="card-icon bg-secondary">
                    <i class="bi bi-clock-history text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Shift Report</h5>
                    <p class="card-description">Review shift performance and totals</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6 mb-4">
            <div class="modern-card h-100" @onclick="GoToDaySalesReport">
                <div class="card-icon bg-dark">
                    <i class="bi bi-graph-up-arrow text-white"></i>
                </div>
                <div class="card-content">
                    <h5 class="card-title">Day Sales Report</h5>
                    <p class="card-description">View daily sales totals and trends</p>
                    <div class="card-arrow">
                        <i class="bi bi-arrow-right"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!UserSession.IsUserLoggedIn())
        {
            Navigation.NavigateTo("/", true);
        }
    }
    void GoToEnquiry() => Navigation.NavigateTo("/enquiry");
    void GoToInventoryDeliveriesManagement() => Navigation.NavigateTo("/inventory-management/deliveries");
    void GoToInventoryTransfers() => Navigation.NavigateTo("/inventory-management/transfers");
    void GoToInventoryOrders() => Navigation.NavigateTo("/inventory-management/orders");
    void GoToInventoryAlerts() => Navigation.NavigateTo("/inventory-management/alerts");
    void GoToInventoryProducts() => Navigation.NavigateTo("/inventory-management/products");
    void GoToInventorySuppliers() => Navigation.NavigateTo("/inventory-management/suppliers");
    void GoToInventorySupplierItems() => Navigation.NavigateTo("/inventory-management/supplier-items");
    void GoToStockRefill() => Navigation.NavigateTo("/stock-refill");
    void GoToTransactionHistory()
    {
        Navigation.NavigateTo("/transaction-history");

    }
    async void GoToShiftReport() 
    {
        await UserSession.EnsureShiftAsync();
        Navigation.NavigateTo($"/sales-dashboard/shift/{UserSession?.CurrentShift?.Id}");
    }
    async void GoToDaySalesReport()
    {
        await UserSession.EnsureDayLogAsync();
        Navigation.NavigateTo($"/sales-dashboard/daylog/{UserSession?.CurrentDayLog?.Id}");
    }
}
